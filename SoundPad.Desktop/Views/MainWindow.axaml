<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SoundPad.Desktop.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="SoundPad.Desktop.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="SoundPad.Desktop"
        MinWidth="1124" MinHeight="1024">

    <Design.DataContext>
        <vm:MainViewModel/>
    </Design.DataContext>

    <SplitView PanePlacement="Left" DisplayMode="CompactInline" IsPaneOpen="True" OpenPaneLength="200">
        <SplitView.Pane>
            <Grid RowDefinitions="Auto, Auto, Auto, *" RowSpacing="8">
                <Button Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Content="Soundpad" Command="{Binding SelectViewCommand}" CommandParameter="0" />
                <Button Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Content="Settings" Command="{Binding SelectViewCommand}" CommandParameter="1" />
                <Button Grid.Row="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Content="About" Command="{Binding SelectViewCommand}" CommandParameter="2" />
            </Grid>
        </SplitView.Pane>
        <ContentControl Content="{Binding SelectedContent}" />
    </SplitView>
    <!-- <Panel> -->
    <!--     <ListBox Width="200" Background="#1e1e1e" Foreground="White" -->
    <!--              ItemsSource="['Soundpad', 'Settings', 'About']" -->
    <!--              SelectedIndex="{Binding SelectedTabIndex}" -->
    <!--              Padding="16,8" FontSize="14"> -->
    <!--         <ListBox.ItemContainerStyle> -->
    <!--             <Style Selector="ListBoxItem"> -->
    <!--                 <Setter Property="Background" Value="Transparent"/> -->
    <!--                 <Setter Property="Padding" Value="16,8"/> -->
    <!--             </Style> -->
    <!--             <Style Selector="ListBoxItem:selected"> -->
    <!--                 <Setter Property="Background" Value="#3a3a3a"/> -->
    <!--             </Style> -->
    <!--         </ListBox.ItemContainerStyle> -->
    <!--     </ListBox> -->
    <!--      -->
    <!--      -->
    <!-- </Panel> -->

</Window>
