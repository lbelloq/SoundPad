<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SoundPad.Desktop.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:SoundPad.Desktop.Models"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="800"
             x:Class="SoundPad.Desktop.Views.PadView"
             x:DataType="vm:PadViewModel">

    <Design.DataContext>
        <vm:PadViewModel/>
    </Design.DataContext>

    <Border Classes="view">
        <ItemsControl ItemsSource="{Binding Buttons}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:PadButton">
                    <Button Content="{Binding}" Classes="pad" Command="{Binding $parent[UserControl].((vm:PadViewModel)DataContext).PlayCommand }" CommandParameter="{Binding}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="8" Columns="8" ColumnSpacing="8" RowSpacing="8"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
    </Border>

</UserControl>
